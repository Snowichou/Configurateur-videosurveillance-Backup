{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js,.mjs",
    "lint:fix": "eslint src --ext .js,.mjs --fix",
    "format": "prettier --write \"src/**/*.{js,mjs,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,mjs,css,html}\""
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.15.0",
    "happy-dom": "^15.11.0",
    "prettier": "^3.4.0",
    "vite": "^7.2.4",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0"
  }
}
