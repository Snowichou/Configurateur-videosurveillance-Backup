exports[`Snapshot — renderMountRecapPanel > récap avec 13 caméras et 21 accessoires 1`] = `
"
    <div class="recapPanel" role="region" aria-label="Récap fixations">
      <div class="recapHeader">
        <div class="recapStep">🔧 <span>Étape Fixations</span></div>
        <div class="recapTitle">Synthèse des accessoires</div>
      </div>
      <div class="mountRecapKpis">
        <div class="mountRecapKpi">
          <div class="mountRecapKpiValue">13</div>
          <div class="mountRecapKpiLabel">caméras</div>
        </div>
        <div class="mountRecapKpi mountRecapKpiAccent">
          <div class="mountRecapKpiValue">21</div>
          <div class="mountRecapKpiLabel">accessoires</div>
        </div>
      </div>
      <div class="mountRecapChips"><span class="mountRecapChip"><span class="mountRecapChipIcon">📦</span><strong>13</strong> <span class="mountRecapChipLabel">Boîtier raccordement</span></span><span class="mountRecapChip"><span class="mountRecapChipIcon">🧱</span><strong>8</strong> <span class="mountRecapChipLabel">Support</span></span></div>
    </div>
  "
`;

