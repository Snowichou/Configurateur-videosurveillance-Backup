exports[`Snapshot — wizardTipHtml > tip ADVANCE rendu standard 1`] = `
"
    <div class="wizardTip" role="note" data-tipid="tip:where:advance">
      <span class="wizardTipIcon">🧠</span>
      <div class="wizardTipBody">
        <div class="wizardTipTitle">ADVANCE = analyses avancées</div>
        <div class="wizardTipText">L'IA ADVANCE active comptage de personnes, métadonnées (couleur, taille), reconnaissance de plaques (LPR).</div>
      </div>
      <button type="button" class="wizardTipClose"
        data-action="dismissWizardTip" data-tipid="tip:where:advance"
        aria-label="Masquer l'astuce" title="Ne plus afficher">✕</button>
    </div>
  "
`;

